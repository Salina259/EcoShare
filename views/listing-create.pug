extends layout

block content
  section.listing-create-page
    h2.page-title Create Listing

    .item-card
      form(action='/listings', method='post')
        p
          label(for='title') Title
          br
          input(type='text', id='title', name='title', required)

        p
          label(for='description') Description
          br
          textarea(id='description', name='description', rows='4')

        p
          label(for='category_id') Category
          br
          select(id='category_id', name='category_id')
            option(value='') Select a category
            if categories && categories.length
              each category in categories
                option(value=category.category_id)= category.name

        p
          label(for='availability') Availability
          br
          input(type='text', id='availability', name='availability', placeholder='e.g. Weekends')

        p
          label(for='status') Status
          br
          select(id='status', name='status')
            option(value='available', selected=true) available
            option(value='pending') pending
            option(value='shared') shared

        p
          label(for='user_id') User ID
          br
          input(type='number', id='user_id', name='user_id', min='1', placeholder='e.g. 1')

        p
          label(for='tags') Tags (comma-separated)
          br
          input(type='text', id='tags', name='tags', placeholder='books, eco-friendly, reusable')

        button.btn(type='submit') Save Listing

    a.back-link(href='/listings') ← Back to Listings
