extends layout

block content
  section.listings-page
    h2.page-title Browse Items

    .search-bar
      form.inline-form(action='/listings', method='get')
        select(name='tag')
          option(value='') All tags
          if availableTags && availableTags.length
            each t in availableTags
              option(value=t.name, selected=selectedTag === t.name)= t.name
        button(type='submit') Filter by Tag
      if selectedTag
        a.btn(href='/listings') Clear Filter
      a.btn(href='/listings/new') + New Listing

    if items && items.length
      .items-grid
        each item in items
          .item-card
            h3= item.title

            p
              strong Category:
              |  #{item.category_name || 'N/A'}

            p
              strong Availability:
              |  #{item.availability || 'N/A'}

            p
              strong Status:
              |  #{item.status || 'N/A'}

            p
              strong Owner:
              |  #{item.owner_name || 'N/A'}

            if item.description
              p= item.description

            if item.tag_names
              .tags-row
                each tagName in item.tag_names.split(', ')
                  span.tag-badge= tagName

            a.btn(href=`/items/${item.listing_id}`) View Details
    else
      p No items available.