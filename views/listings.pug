extends layout

block content
  section.listings-page
    h2.page-title Browse Items

    .search-bar
      input(type='text', placeholder='Search items...')
      button(type='button') Search

    if items && items.length
      .items-grid
        each item in items
          .item-card
            h3= item.title

            p
              strong Category:
              |  #{item.category_name || 'N/A'}

            p
              strong Availability:
              |  #{item.availability || 'N/A'}

            p
              strong Status:
              |  #{item.status || 'N/A'}

            p
              strong Owner:
              |  #{item.owner_name || 'N/A'}

            if item.description
              p= item.description

            a.btn(href=`/items/${item.listing_id}`) View Details
    else
      p No items available.