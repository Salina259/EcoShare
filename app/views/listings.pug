extends layout

block content
  .container
    h2 Listings

    // SEARCH BAR (UI only for now)
    form(action="/listings", method="GET")
      input(type="text", name="search", placeholder="Search items...")
      button(type="submit") Search

    // CHECK IF ITEMS EXIST
    if items && items.length > 0
      .grid
        each item in items
          .card
            h3= item.title

            p
              strong Category:
              |  #{item.category_name}

            p
              strong Owner:
              |  #{item.owner_name}

            p
              strong Status:
              |  #{item.status}

            if item.description
              p= item.description

            a.btn(href=`/listings/${item.listing_id}`) View Details

    else
      p No items available
